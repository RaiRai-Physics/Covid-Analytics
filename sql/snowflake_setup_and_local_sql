--Create warehouse, datanase, and schemas
CREATE OR REPLACE WAREHOUSE COVID_WH
  WAREHOUSE_SIZE = 'XSMALL';

CREATE OR REPLACE DATABASE COVID_ANALYTICS_DB;

CREATE OR REPLACE SCHEMA COVID_ANALYTICS_DB.STAGE;
CREATE OR REPLACE SCHEMA COVID_ANALYTICS_DB.CURATED;

--Create Snowflake storage integration
CREATE OR REPLACE STORAGE INTEGRATION COVID_S3_INT
  TYPE = EXTERNAL_STAGE
  STORAGE_PROVIDER = 'S3'
  ENABLED = TRUE
  STORAGE_AWS_ROLE_ARN = 'arn:aws:iam::952567463517:role/covid-analytics-snowflake'
  STORAGE_ALLOWED_LOCATIONS = ('s3://covid-analytics-etl/covid/');

DESC INTEGRATION COVID_S3_INT;

--Create the file format and external stage

CREATE OR REPLACE FILE FORMAT COVID_ANALYTICS_DB.STAGE.PARQUET_FF
  TYPE = PARQUET
  USE_VECTORIZED_SCANNER = TRUE
  USE_LOGICAL_TYPE = TRUE;

CREATE OR REPLACE STAGE COVID_ANALYTICS_DB.STAGE.COVID_GOLD_STAGE
  STORAGE_INTEGRATION = COVID_S3_INT
  URL = 's3://covid-analytics-etl/covid/gold/'
  FILE_FORMAT = COVID_ANALYTICS_DB.STAGE.PARQUET_FF;

  --Create target Snowflake tables
  CREATE OR REPLACE TABLE COVID_ANALYTICS_DB.CURATED.DIM_DATE (
  DATE_ID INT,
  FULL_DATE DATE,
  YEAR INT,
  MONTH INT,
  DAY INT,
  DOW INT,
  IS_WEEKEND BOOLEAN
);

CREATE OR REPLACE TABLE COVID_ANALYTICS_DB.CURATED.DIM_STATE (
  STATE_CODE STRING,
  STATE_NAME STRING
);

CREATE OR REPLACE TABLE COVID_ANALYTICS_DB.CURATED.FACT_CASES_STATE_DAILY (
  DATE_ID INT,
  STATE_CODE STRING,
  CASES_CUM BIGINT,
  DEATHS_CUM BIGINT,
  NEW_CASES INT,
  NEW_DEATHS INT
);

CREATE OR REPLACE TABLE COVID_ANALYTICS_DB.CURATED.FACT_TESTING_STATE_DAILY (
  DATE_ID INT,
  STATE_CODE STRING,
  TESTS_TOTAL_CUM BIGINT,
  TESTS_POS_CUM BIGINT,
  TESTS_NEG_CUM BIGINT,
  NEW_TESTS INT,
  POSITIVITY_RATE FLOAT
);

--Load Gold Parquet into Snowflake

COPY INTO COVID_ANALYTICS_DB.CURATED.DIM_DATE
FROM @COVID_ANALYTICS_DB.STAGE.COVID_GOLD_STAGE/dim_date/
MATCH_BY_COLUMN_NAME = CASE_INSENSITIVE;

COPY INTO COVID_ANALYTICS_DB.CURATED.DIM_STATE
FROM @COVID_ANALYTICS_DB.STAGE.COVID_GOLD_STAGE/dim_state/
MATCH_BY_COLUMN_NAME = CASE_INSENSITIVE;

COPY INTO COVID_ANALYTICS_DB.CURATED.FACT_CASES_STATE_DAILY
FROM @COVID_ANALYTICS_DB.STAGE.COVID_GOLD_STAGE/fact_cases_state_daily/
MATCH_BY_COLUMN_NAME = CASE_INSENSITIVE;

COPY INTO COVID_ANALYTICS_DB.CURATED.FACT_TESTING_STATE_DAILY
FROM @COVID_ANALYTICS_DB.STAGE.COVID_GOLD_STAGE/fact_testing_state_daily/
MATCH_BY_COLUMN_NAME = CASE_INSENSITIVE;

--Validation

SELECT COUNT(*) AS total_rows,
       COUNT(STATE_CODE) AS non_null_state_code_rows
FROM COVID_ANALYTICS_DB.CURATED.FACT_TESTING_STATE_DAILY;

SELECT COUNT(*) AS null_state_code_rows
FROM COVID_ANALYTICS_DB.CURATED.FACT_TESTING_STATE_DAILY
WHERE STATE_CODE IS NULL;

SELECT STATE_CODE, COUNT(*) AS row_count
FROM COVID_ANALYTICS_DB.CURATED.FACT_TESTING_STATE_DAILY
GROUP BY STATE_CODE
ORDER BY row_count DESC;

SELECT STATE_CODE, COUNT(*) AS row_count
FROM COVID_ANALYTICS_DB.CURATED.FACT_CASES_STATE_DAILY
GROUP BY STATE_CODE
ORDER BY row_count DESC;

--Top 5 States by new cases on a given date
SELECT s.state_name, f.new_cases
FROM COVID_ANALYTICS_DB.CURATED.FACT_CASES_STATE_DAILY f
JOIN COVID_ANALYTICS_DB.CURATED.DIM_STATE s
  ON s.state_code = f.state_code
WHERE f.date_id = (
    SELECT MAX(date_id)
    FROM COVID_ANALYTICS_DB.CURATED.FACT_CASES_STATE_DAILY
)
ORDER BY f.new_cases DESC
LIMIT 5;

--Positivity trend for a state
SELECT d.full_date,
       t.positivity_rate
FROM COVID_ANALYTICS_DB.CURATED.FACT_TESTING_STATE_DAILY t
JOIN COVID_ANALYTICS_DB.CURATED.DIM_DATE d
  ON d.date_id = t.date_id
WHERE t.state_code = 'NY'
ORDER BY d.full_date;

--Cases vs tests for California
SELECT d.full_date,
       c.new_cases,
       t.new_tests,
       t.positivity_rate
FROM COVID_ANALYTICS_DB.CURATED.FACT_CASES_STATE_DAILY c
JOIN COVID_ANALYTICS_DB.CURATED.FACT_TESTING_STATE_DAILY t
  ON t.date_id = c.date_id
 AND t.state_code = c.state_code
JOIN COVID_ANALYTICS_DB.CURATED.DIM_DATE d
  ON d.date_id = c.date_id
WHERE c.state_code = 'CA'
ORDER BY d.full_date;

